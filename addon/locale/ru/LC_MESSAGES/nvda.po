msgstr "Последняя страница удалена"

#: addon/globalPlugins/scanvox/__init__.py:404
msgid "There are no pages to delete"
msgstr "Нет страниц для удаления"

#: addon/globalPlugins/scanvox/__init__.py:423
#: addon/globalPlugins/scanvox/__init__.py:440
msgid "End"
msgstr "Завершить"

#: addon/globalPlugins/scanvox/settings.py:23
msgid "General"
msgstr "Общее"

