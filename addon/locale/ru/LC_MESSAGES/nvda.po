msgstr "Автоматический поиск обновлений"

#: addon/globalPlugins/scanvox/settings.py:77
msgid "Search for an update now"
msgstr "Проверить наличие обновлений"

#: addon/globalPlugins/scanvox/update.py:26
#, python-format
msgid "Update of %s version %s"
msgstr "Обновление %s версия %s"

#: addon/globalPlugins/scanvox/update.py:29
#, python-format
msgid ""
"%s version %s is available. Would you like to update now? You can view the "
"changes by clicking on the What's New button and scrolling down to Changes."
msgstr ""
"Доступно %s версия %s. Хотели бы вы обновиться сейчас? Вы можете просмотреть "
"изменения, нажав на кнопку \"Что нового\" и прокрутив страницу вниз до "
"описания изменений."

#: addon/globalPlugins/scanvox/update.py:42
msgid "The update could not be downloaded. Please try again later."
msgstr "Не удалось загрузить обновление. Пожалуйста, повторите попытку позже."

#: addon/globalPlugins/scanvox/update.py:85
#: addon/globalPlugins/scanvox/update.py:110
msgid "No internet connection."
msgstr "Нет подключения к Интернету."

#: addon/globalPlugins/scanvox/update.py:122
msgid "No update is available."
msgstr "Обновление недоступно."

#: addon/globalPlugins/scanvox/update.py:140
msgid "&Yes"
msgstr "&Да"

#: addon/globalPlugins/scanvox/update.py:149
msgid "&No"
msgstr "&Нет"

#: addon/globalPlugins/scanvox/update.py:155
msgid "Wha&t's new"
msgstr "Что нового"

#: buildVars.py:27
msgid ""
"This add-on allows you to read paper documents using the Scanvox software. "
"To use it, go to the NVDA menu and select Scanvox."
msgstr ""
"Это дополнение позволяет вам читать бумажные документы с помощью программы "
"Scanvox. Чтобы использовать его, перейдите в меню NVDA и выберите Scanvox "
"для NVDA."

